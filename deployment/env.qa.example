# Local-only deployment configuration for the QA target.
# Keep credentials here only if you explicitly accept the risk of plaintext secrets.

REMOTE_HOST="127.0.0.1"
REMOTE_PORT="22"
REMOTE_USER="deployuser"
REMOTE_PASSWORD=""
REMOTE_SUDO_PASSWORD=""
REMOTE_DEPLOY_ROOT="/var/www/reflecto-ai-qa"
LOCAL_SOURCE_PATH="C:/projects/reflecto-ai"

DEPLOY_COMPOSE_FILE="docker-compose.prod.yml"
COMPOSE_PROJECT_NAME="reflecto-ai-qa"
DEPLOY_REF="HEAD"
DEPLOY_USE_GIT_ARCHIVE="true"
DEPLOY_INSTALL_DOCKER_IF_MISSING="true"
DEPLOY_RETAIN_RELEASES="3"
SSH_STRICT_HOST_KEY_CHECKING="accept-new"

RELEASE_NOTES_ENABLED="false"
RELEASE_AGENT_GROQ_API_KEY=""
RELEASE_AGENT_DIR="C:\projects\nexus-ai\ai-agents\release"
RELEASE_NOTES_PREVIOUS_BRANCH="main"
