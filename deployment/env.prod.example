# Deployment configuration — production target.
# Copy this file to env.prod and fill in real values (env.prod is gitignored).
# Keep credentials here only if you explicitly accept the risk of plaintext secrets.
#
# Usage:
#   .\deployment\deploy.ps1               # uses env.prod by default
#   .\deployment\deploy.ps1 prod auto     # explicit environment + mode

# ── Remote Server (required) ─────────────────────────────────────────────────

REMOTE_HOST="192.168.117.144"
REMOTE_PORT="22"
REMOTE_USER="refluser"
REMOTE_PASSWORD=""
REMOTE_SUDO_PASSWORD=""          # defaults to REMOTE_PASSWORD if blank
REMOTE_DEPLOY_ROOT="/var/www/reflecto-ai"
LOCAL_SOURCE_PATH="C:/projects/reflecto-ai"

# ── Docker / Compose ─────────────────────────────────────────────────────────

DEPLOY_COMPOSE_FILE="docker-compose.prod.yml"
COMPOSE_PROJECT_NAME="reflecto-ai-prod"

# ── Git Archive ──────────────────────────────────────────────────────────────

DEPLOY_REF="HEAD"                          # git ref to deploy; HEAD = current branch tip
DEPLOY_USE_GIT_ARCHIVE="true"              # true = committed files only; false = working tree

# ── Deployment Behaviour ─────────────────────────────────────────────────────

DEPLOY_INSTALL_DOCKER_IF_MISSING="true"   # auto-install Docker on remote if absent
DEPLOY_RETAIN_RELEASES="3"                # number of releases to keep on the server
SSH_STRICT_HOST_KEY_CHECKING="accept-new" # accept-new | yes | no

# ── Release Notes (optional) ─────────────────────────────────────────────────
#
# When RELEASE_NOTES_ENABLED=true, deploy.ps1 calls tools/release-notes.ps1
# (which calls tools/release-notes.exe) to generate AI release notes before
# packaging. At least ONE LLM key must be set; others can be left blank.
#
# The binary reads whichever key is set as an environment variable.
# Set at least one:

RELEASE_NOTES_ENABLED="false"
RELEASE_NOTES_PREVIOUS_BRANCH="main"      # branch to diff current branch against

# Groq (free tier — recommended for getting started: https://console.groq.com/keys)
RELEASE_AGENT_GROQ_API_KEY=""

# Google Gemini (https://aistudio.google.com/app/apikey)
RELEASE_AGENT_GEMINI_API_KEY=""

# Anthropic Claude (https://console.anthropic.com/settings/keys)
RELEASE_AGENT_ANTHROPIC_API_KEY=""
