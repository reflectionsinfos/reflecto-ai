# Release Notes Agent — environment configuration
# Copy this file to .env.local for local use (gitignored).
#
# The agent reads keys in this priority order:
#   1. Shell environment variables (highest — set by deploy.ps1 or manually)
#   2. .env.local  — local developer overrides
#   3. .env        — base defaults (if present in agent directory)
#
# Set at least ONE LLM provider key. The active provider is configured
# inside the nexus-ai release agent's own .env.local (PER_REPO_LLM_PROVIDER,
# SYNTHESIS_LLM_PROVIDER). Keys left blank are simply ignored.

# ── LLM API Keys ────────────────────────────────────────────────────────────

# Groq (free tier available — recommended for getting started)
# https://console.groq.com/keys
GROQ_API_KEY=

# Google Gemini
# https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Anthropic Claude
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# ── Agent Behaviour (optional overrides) ─────────────────────────────────────

# Branch to diff the current release against (default: main)
# RELEASE_NOTES_PREVIOUS_BRANCH=main

# Disable the interactive approval step (always off in CI / deploy.ps1)
# APPROVAL_STEP=false

# Maximum diff characters sent to the LLM per repo (default: 120000)
# MAX_DIFF_CHARS=120000
